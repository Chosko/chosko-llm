#!/usr/bin/env bash
set -euo pipefail

CHOSKO_LLM_HOME="${CHOSKO_LLM_HOME:-$HOME/.chosko-llm}"

if [ ! -d "$CHOSKO_LLM_HOME" ]; then
  echo "chosko-llm: managed clone not found at $CHOSKO_LLM_HOME" >&2
  echo "Run install.sh first." >&2
  exit 1
fi

subcommand="${1:-}"
[ $# -gt 0 ] && shift || true

# Daily auto-upgrade (opt-in; first command of the day). Guarded so an older
# install without the hook script still works, and `|| true` so it can never
# block the user's actual command.
if [ -x "$CHOSKO_LLM_HOME/scripts/auto-upgrade.sh" ]; then
  "$CHOSKO_LLM_HOME/scripts/auto-upgrade.sh" "$subcommand" || true
fi

case "$subcommand" in
  ls|add|rm|update|upgrade|show|uninstall)
    exec "$CHOSKO_LLM_HOME/scripts/cmd-${subcommand}.sh" "$@"
    ;;
  task-impl)
    exec "$CHOSKO_LLM_HOME/scripts/cmd-task-impl.sh" "$@"
    ;;
  ""|-h|--help|help)
    if [ -x "$CHOSKO_LLM_HOME/scripts/cmd-help.sh" ]; then
      exec "$CHOSKO_LLM_HOME/scripts/cmd-help.sh" "$@"
    else
      cat "$CHOSKO_LLM_HOME/docs/cli-help.txt"
    fi
    ;;
  *)
    echo "chosko-llm: unknown subcommand: $subcommand" >&2
    echo "Run 'chosko-llm help' for usage." >&2
    exit 2
    ;;
esac
